{
  "expo": {
    "name": "HomeMaid",
    "slug": "homemaid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "homemaid",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "live.jaiswals.homemaid"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "live.jaiswals.homemaid"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        { "cameraPermission": "Allow HomeMaid to access your camera for scanning receipts." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow HomeMaid to access your photos for scanning receipts." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
